{
  "name": "inspirejs.org",
  "version": "2.1.0",
  "description": "Lean, hackable, extensible slide deck framework",
  "main": "inspire.mjs",
  "exports": {
    ".": "./inspire.mjs",
    "./inspire.css": {
      "style": "./inspire.css",
      "default": "./inspire.css"
    },
    "./theme.css": {
      "style": "./theme.css",
      "default": "./theme.css"
    },
    "./style/*": {
      "style": "./style/*",
      "default": "./style/*"
    },
    "./plugins/*": "./plugins/*/plugin.js"
  },
  "scripts": {
    "build": "echo \"No build process! 🤟🏼\" && exit 0",
    "watch": "echo \"No build process! 🤟🏼\" && exit 0",
    "test": "echo \"Error: no test specified\" && exit 1",
    "release": "npm login && npx release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeaVerou/inspire.js.git"
  },
  "keywords": [
    "slides"
  ],
  "author": "Lea Verou",
  "funding": [
    {
      "type": "individual",
      "url": "https://github.com/sponsors/LeaVerou"
    },
    {
      "type": "opencollective",
      "url": "https://opencollective.com/leaverou"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LeaVerou/inspire.js/issues"
  },
  "homepage": "https://inspirejs.org",
  "dependencies": {
    "blissful-hooks": "^0.0"
  },
  "devDependencies": {
    "release-it": "^20.0.1"
  }
}
